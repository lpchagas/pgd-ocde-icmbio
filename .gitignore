# =============================================================================
# .gitignore — DM_Petrvs_icmbio_mysql
# Atualizado em 17.06.2026
# Princípio: tudo que contenha credenciais, dados pessoais, caminhos locais
# ou artefatos operacionais não publicáveis deve estar aqui.
# =============================================================================

# -----------------------------------------------------------------------------
# Credenciais e configuração local (NUNCA versionar)
# -----------------------------------------------------------------------------
.env
.env.local
*.local
.secrets.baseline

# -----------------------------------------------------------------------------
# Instruções e memória dos agentes locais (contêm credenciais e contexto privado)
# -----------------------------------------------------------------------------
CLAUDE.md
AGENTS.md
.claude/
.codex/

# -----------------------------------------------------------------------------
# Antigravity Desktop — agentes e metadados do projeto (uso local)
# -----------------------------------------------------------------------------
.agents/
PROJECT.md

# -----------------------------------------------------------------------------
# Skills locais (desenvolvimento interno — não sincronizar com GitHub)
# -----------------------------------------------------------------------------
.github/skills/

# -----------------------------------------------------------------------------
# Dumps do banco PETRVS (nunca versionar — arquivo > 4 GB com dados pessoais)
# -----------------------------------------------------------------------------
*.sql
*.sql.gz
*.sql.zip
_dump/
dump/

# -----------------------------------------------------------------------------
# Artefatos locais — CSVs mensais, diagnósticos, validações, backup de scripts
# Estrutura atual (reestruturada em 17.06.2026):
#   artefatos_local/
#     entregas/YYYY-MM/          ← CSVs mensais para entrega à COCAGE/Power BI
#     diagnosticos/YYYY-MM/      ← Scripts A4 e CSVs diagnósticos (uso interno)
#     validacao/                 ← Relatórios A5 (.md) e PDFs de consulta A3
#     docs_internos/             ← Documentação local não publicável
#     historico/                 ← Artefatos legados (dump mai-2026, denodo mai-2026)
#     backup_scripts_a1/         ← Cópias de segurança dos scripts A1
# -----------------------------------------------------------------------------
artefatos_local/

# -----------------------------------------------------------------------------
# Pastas legadas (migradas para artefatos_local/ em 17.06.2026 — mantidas aqui
# por segurança caso ressurjam localmente)
# -----------------------------------------------------------------------------
Tabelas CSV/
Testes PETRVS/

# -----------------------------------------------------------------------------
# Dados brutos exportados — podem conter dados pessoais de servidores
# -----------------------------------------------------------------------------
*.csv
*.xlsx
*.xls

# -----------------------------------------------------------------------------
# Apresentações e PDFs (podem conter dados operacionais sensíveis)
# -----------------------------------------------------------------------------
*.pdf
*.pptx
*.ppt

# -----------------------------------------------------------------------------
# Notebooks Jupyter (podem conter credenciais e resultados de consultas)
# Exceção: o template público não tem credenciais e serve de referência para a APF
# -----------------------------------------------------------------------------
*.ipynb
!consultas_denodo_template.ipynb

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# -----------------------------------------------------------------------------
# Logs de execução
# -----------------------------------------------------------------------------
*.log

# -----------------------------------------------------------------------------
# VS Code — configurações locais (settings globais são versionados via settings.json)
# -----------------------------------------------------------------------------
.vscode/settings.local.json

# -----------------------------------------------------------------------------
# Arquivo de workspace do VS Code (contém caminhos absolutos locais)
# -----------------------------------------------------------------------------
*.code-workspace

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Pasta aninhada criada em sessão anterior (pode ser deletada manualmente)
# -----------------------------------------------------------------------------
/DM_Petrvs_icmbio_mysql/
