# Credenciais de acesso ao Denodo — copie este arquivo como .env e preencha com seus dados
# NUNCA commitar o arquivo .env — ele contém sua senha pessoal
#
# Como usar:
#   1. Copie este arquivo com o nome .env (sem o .example)
#   2. Abra o arquivo .env com o Bloco de Notas
#   3. Preencha os campos DENODO_USER, DENODO_PASSWORD e DENODO_DRIVER_PATH
#   4. Salve — pronto

# ─── Java (instalado automaticamente pelo DBeaver) ────────────────────────────
# Caminho padrão quando o DBeaver está instalado na pasta padrão do Windows.
# Alterar apenas se o DBeaver estiver instalado em local diferente.
JAVA_HOME=C:/Program Files/DBeaver/jre

# ─── Driver Denodo ────────────────────────────────────────────────────────────
# Caminho do arquivo .jar instalado automaticamente pelo DBeaver na primeira conexão.
# Substitua SEU_USUARIO pelo nome do seu usuário Windows (ex.: joao.silva).
# Para descobrir seu usuário: abra o Prompt de Comando e digite  echo %USERNAME%
DENODO_DRIVER_PATH=C:/Users/SEU_USUARIO/AppData/Roaming/DBeaverData/drivers/remote/drivers/jdbc/9/denodo-vdp-jdbcdriver.jar

# ─── Conexão Denodo ───────────────────────────────────────────────────────────
# Não alterar — são os dados fixos do servidor do governo (Dataprev/MGI)
DENODO_HOST=denodo-pgd.dataprev.gov.br
DENODO_PORT=443
DENODO_DATABASE=petrvs_icmbio

# ─── Suas credenciais individuais ─────────────────────────────────────────────
# Fornecidas pelo gestor responsável pelo PGD no seu órgão.
# DENODO_USER: seu CPF sem pontos, traço ou dígito verificador (11 dígitos)
DENODO_USER=seu_cpf_aqui
DENODO_PASSWORD=sua_senha_aqui
